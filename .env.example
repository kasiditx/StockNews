# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Comma-separated symbols. Thai stocks usually use .BK suffix in Yahoo Finance.
# Example only, not investment advice:
# STOCK_WATCHLIST=PTT.BK,AOT.BK,ADVANC.BK,NVDA,AAPL
STOCK_WATCHLIST=

# To scan a broad universe instead of a hand-picked watchlist:
# STOCK_WATCHLIST=ALL
# STOCK_UNIVERSE=US
#
# US symbols are fetched from Nasdaq Trader symbol directories.
# TH symbols are loaded from STOCK_UNIVERSE_TH_FILE because Thai market lists
# should be maintained from a reliable current export.
STOCK_UNIVERSE=US
# Comma-separated business groups to scan when STOCK_WATCHLIST=ALL.
# Blank means no sector filter. Default groups map to provider sectors:
# Technology, Industrials, Services, Financials, Consumer Products.
STOCK_SECTORS=Technology,Industrials,Services,Financials,Consumer Products
STOCK_UNIVERSE_TH_FILE=config/universe.th.csv

# Safety cap for broad universe scans. Set 0 only if you accept long runtime and provider limits.
# 0 means no cap. This can take a long time for broad universes.
MAX_SYMBOLS_PER_RUN=0

# Alert behavior
ALERT_INTERVAL_MINUTES=60
MAX_NEWS_PER_SYMBOL=3
# Limit news lookups after technical filtering. 0 disables news lookup; blank means default.
MAX_NEWS_LOOKUPS_PER_RUN=20
MIN_SCORE_TO_ALERT=4
# Limit notifications to the strongest candidates. Set 0 only if you want every match.
TOP_ALERTS_PER_RUN=20
